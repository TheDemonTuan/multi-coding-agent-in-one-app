{
  "name": "tdt-space",
  "productName": "TDT Space",
  "version": "0.1.2",
  "description": "Multi-Agent Terminal for TDT Vibe Coding",
  "author": "TDT Space Team",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "wails:dev": "wails3 dev",
    "wails:build": "wails3 build",
    "wails:build:prod": "cd .. && task build",
    "wails:build:installer": "cd .. && task package",
    "wails:build:windows": "cd .. && task windows:build",
    "wails:build:linux": "cd .. && task linux:build",
    "wails:build:macos": "cd .. && task darwin:build",
    "wails:build:macos-arm": "cd .. && task darwin:build",
    "wails:build:all": "cd .. && task build"
  },
  "dependencies": {
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "@xterm/addon-clipboard": "beta",
    "@xterm/addon-fit": "beta",
    "@xterm/addon-search": "beta",
    "@xterm/addon-web-links": "beta",
    "@xterm/addon-webgl": "beta",
    "@xterm/xterm": "beta",
    "svelte": "^5.53.12"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.5.0",
    "lightningcss": "^1.32.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "svelte-check": "^4.4.5",
    "terser": "^5.46.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
