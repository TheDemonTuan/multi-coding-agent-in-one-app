# Required
OPENCODE_API_KEY="your_opencode_api_key_here"

# Server Configuration
OPENCODE_PROXY_PORT=8080
OPENCODE_BASE_URL="https://opencode.ai/zen/go"
OPENCODE_PROXY_LOG_LEVEL="info"
OPENCODE_PROXY_LOG_FILE=""

# Timeout Configuration
OPENCODE_REQUEST_TIMEOUT="120s"
OPENCODE_DIAL_TIMEOUT="30s"
OPENCODE_TLS_HANDSHAKE_TIMEOUT="10s"
OPENCODE_RESPONSE_HEADER_TIMEOUT="10s"

# Rate Limiting
OPENCODE_RATE_LIMIT_RPS=100
OPENCODE_RATE_LIMIT_BURST=200

# Concurrency Control
OPENCODE_MAX_CONCURRENT_REQUESTS=50

# Request Deduplication (Singleflight)
OPENCODE_ENABLE_DEDUPLICATION=true
OPENCODE_DEDUP_TTL="30s"

# Response Caching
OPENCODE_ENABLE_CACHING=true
OPENCODE_CACHE_TTL="5m"

# Retry Logic
OPENCODE_ENABLE_RETRY=true
OPENCODE_MAX_RETRIES=3
OPENCODE_RETRY_INITIAL_BACKOFF="500ms"
OPENCODE_RETRY_MAX_BACKOFF="5s"
OPENCODE_RETRY_MULTIPLIER=2.0
