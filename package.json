{
  "name": "tdt-space",
  "productName": "TDT Space",
  "version": "1.0.0",
  "description": "Multi-Agent Terminal for TDT Vibe Coding",
  "author": "TDT Space Team",
  "main": "dist-electron/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:electron": "tsc && vite build",
    "preview": "vite preview",
    "electron:start": "cross-env ELECTRON_IS_DEV=0 electron .",
    "electron:build": "bun run build && bun run package",
    "electron:only": "electron .",
    "package": "node scripts/package.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^8.2.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.1",
    "zustand": "^4.5.0"
  }, 
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.tdt-space.app",
    "productName": "TDT Space",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/@xterm/**/*"
    ],
    "win": {
      "target": ["dir"]
    },
    "npmRebuild": false,
    "nodeGypRebuild": false
  }
}
